# ============================================================
# Spiritbox — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ---- OpenAI -----------------------------------------------
OPENAI_API_KEY=sk-...

# ---- Anthropic (optional) ----------------------------------
# ANTHROPIC_API_KEY=sk-ant-...

# ---- LangFuse observability --------------------------------
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ---- Weaviate vector store ---------------------------------
WEAVIATE_URL=http://localhost:8081
# WEAVIATE_API_KEY=                   # Required for Weaviate Cloud

# ---- Google Cloud ------------------------------------------
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GCP_PROJECT_ID=my-gcp-project
GCP_REGION=asia-south1
# CLOUD_FUNCTION_URL=https://asia-south1-my-gcp-project.cloudfunctions.net/send-reminder

# ---- PostgreSQL (Cloud SQL) --------------------------------
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/spiritbox

# ---- Model Routing -----------------------------------------
LLM_TIER_1=gpt-4o-mini
LLM_TIER_2=gpt-4o

# ---- Semantic Cache ----------------------------------------
CACHE_SIMILARITY_THRESHOLD=0.95
CACHE_MAX_SIZE=500

# ---- Eval Gate Thresholds ----------------------------------
EVAL_CLASSIFIER_THRESHOLD=0.80
EVAL_ENTITY_F1_THRESHOLD=0.75

# ---- Firestore (legacy, kept during migration) -------------
FIRESTORE_COLLECTION_EVENTS=events

# ---- SendGrid / Email --------------------------------------
# SENDGRID_API_KEY=SG....
REMINDER_FROM_EMAIL=noreply@spiritbox.app

# ---- Admin dashboard ---------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ---- User preferences --------------------------------------
USER_EMAIL=you@example.com
USER_TIMEZONE=Asia/Kolkata
